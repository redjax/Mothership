{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended"
    ],
    "enabledManagers": [
        "pep621",
        "github-actions"
    ],
    "ignorePaths": [
        "submodules/**",
        "**/.gitmodules"
    ],
    "lockFileMaintenance": {
        "enabled": true
    },
    "packageRules": [
        {
            "matchManagers": [
                "pep621"
            ],
            "matchPaths": [
                "scripts/updater/**"
            ],
            "rangeStrategy": "bump"
        },
        {
            "matchManagers": [
                "github-actions"
            ],
            "matchPaths": [
                ".github/workflows/**"
            ]
        }
    ]
}